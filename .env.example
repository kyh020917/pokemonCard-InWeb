# ====================================
# 포켓몬 카드깡 환경변수 설정
# 이 파일을 복사해서 .env 파일 생성 후 값 입력
# cp .env.example .env
# ====================================

# PostgreSQL 연결 문자열 (Supabase에서 복사)
# Supabase > Settings > Database > Connection string > URI
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# NextAuth 시크릿 (랜덤 문자열 - openssl rand -base64 32 로 생성)
NEXTAUTH_SECRET="your-random-secret-here"

# 배포된 URL (Vercel 배포 후 입력, 로컬은 http://localhost:3000)
NEXTAUTH_URL="https://your-app.vercel.app"

# 카카오 개발자 앱 (developers.kakao.com에서 발급)
KAKAO_CLIENT_ID="your-kakao-rest-api-key"
KAKAO_CLIENT_SECRET="your-kakao-client-secret"

# 포켓몬 TCG API (선택, dev.pokemontcg.io에서 무료 발급)
POKEMON_TCG_API_KEY=""
